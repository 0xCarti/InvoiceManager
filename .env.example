SECRET_KEY=change-me
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=change-me
PORT=5000

# Environment mode: development | production
APP_ENV=development

# Database backend: sqlite | postgres
DB_ENGINE=sqlite

# Optional full connection string. If set, this takes precedence.
# DATABASE_URL=postgresql://invoicemanager:change_me@postgres:5432/invoicemanager

# SQLite settings
SQLITE_PATH=/app/data/inventory.db

# PostgreSQL settings
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=invoicemanager
POSTGRES_USER=invoicemanager
POSTGRES_PASSWORD=change_me
POSTGRES_SSLMODE=disable

# Optional host exposure for postgres.
# Keep internal by default with [].
# To expose on host port 5432, set: ["5432:5432"]
POSTGRES_PORTS=[]

SMTP_HOST=
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_USE_TLS=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Use a persistent store (for example redis://redis:6379/0) in production.
RATELIMIT_STORAGE_URI=memory://
